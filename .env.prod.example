# GuardTime production environment — copy to `.env.prod`, fill in every
# placeholder, and NEVER commit the filled-in file (already covered by the
# root .gitignore's `.env*` rule).
#
# Every variable name here matches what backend/dns-service/gateway-agent
# already read (see their own .env.example files) — nothing invented.
# Run the stack with:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ─── PostgreSQL ───
POSTGRES_USER=guardtime
POSTGRES_PASSWORD=change-me-generate-with-openssl-rand-base64-32
POSTGRES_DB=parental_control

# ─── Redis ───
REDIS_PASSWORD=change-me-generate-with-openssl-rand-base64-32

# ─── Backend: JWT (MUST be >= 32 chars each; app refuses to boot otherwise) ───
JWT_SECRET=change-me-64-char-random-string-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-different-64-char-random-string
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Backend: encryption at rest (OAuth tokens, router admin credentials; >= 32 chars) ───
ENCRYPTION_KEY=change-me-exactly-32-characters!

# ─── Backend: CORS (comma-separated allowed browser origins) ───
CORS_ORIGINS=https://your-domain.example,https://www.your-domain.example

# ─── Backend: Microsoft OAuth (Xbox integration) — leave blank to disable ───
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://your-domain.example/oauth/microsoft/callback

# ─── Backend: Firebase Cloud Messaging — leave blank to disable push
# (in-app notifications still work without it) ───
FIREBASE_SERVICE_ACCOUNT_PATH=/opt/guardtime/secrets/firebase-service-account.json

# ─── Backend: DNS/Gateway policy ───
STRICT_MODE=false
DNS_SERVICE_IP=203.0.113.10
# CONTROLLED_DNS_IP=203.0.113.10

# ─── nginx / domain ───
API_DOMAIN=api.your-domain.example
# Paths INSIDE the nginx container — see nginx/certs/ mounted read-only in
# docker-compose.prod.yml. Point certbot's output (or your CA's) there.
CERT_FULLCHAIN_PATH=/etc/nginx/certs/fullchain.pem
CERT_PRIVKEY_PATH=/etc/nginx/certs/privkey.pem
# CIDR nginx trusts for /metrics and internal DNS<->backend routes — use
# 127.0.0.1/32 when dns-service and backend are both containers on this
# same host's compose network (the default topology here).
INTERNAL_CIDR=127.0.0.1/32

# ─── Gateway Agent (only read if you enable `--profile gateway-agent`;
# the recommended production path is the systemd unit instead — see
# gateway-agent/deploy/guardtime-gateway-agent.service and DEPLOYMENT.md) ───
GATEWAY_AGENT_BACKEND_URL=https://api.your-domain.example
GATEWAY_TOKEN=register-a-gateway-in-the-app-first-then-paste-its-token-here

# ─── Monitoring (only read if you enable `--profile monitoring`) ───
GRAFANA_ADMIN_PASSWORD=change-me-generate-with-openssl-rand-base64-24
GRAFANA_ROOT_URL=http://your-domain.example:3300
