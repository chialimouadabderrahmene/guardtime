BACKEND_URL=https://api.waqti.pro
GATEWAY_TOKEN=replace-with-token-from-backend
POLL_INTERVAL_MS=3000

# IP address of your controlled DNS resolver. Usually the gateway LAN IP or the
# production dns-service public IP (169.58.30.9).
DNS_REDIRECT_IP=192.168.1.1
ENABLE_DNS_REDIRECT=true

# Set true for development on non-Linux systems. Logs iptables commands without applying them.
DRY_RUN=false

# Override if binaries live elsewhere on your router image.
IPTABLES_BIN=iptables
CONNTRACK_BIN=conntrack
TC_BIN=tc
PYTHON_BIN=python3
IP_BIN=ip
ARP_BIN=arp

# Level 3 active control.
ENABLE_CONNTRACK_KILL=true
ENABLE_TCP_RST=true
TCP_RST_SNIFF_MS=700

# QoS soft pause. QOS_INTERFACES must be forwarding interfaces, for example br-lan or eth0.
ENABLE_QOS=true
QOS_INTERFACES=br-lan
QOS_RATE=1kbit
QOS_DEFAULT_RATE=1000mbit
