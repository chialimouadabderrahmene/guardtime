# ─── Node / JavaScript ────────────────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/
.cache/
*.tsbuildinfo

# ─── Environment & Secrets ────────────────────────────────────────
.env
*.env
.env.local
.env.*.local
# .env.prod (and any other .env.<name> variant) holds real production
# secrets once filled in from .env.prod.example — never committed. The
# `*.example` templates are the only `.env*` files meant to be tracked.
.env.*
!.env.example
!.env.*.example

# ─── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ─── Dart / Flutter ───────────────────────────────────────────────
parent_app/.dart_tool/
parent_app/build/
parent_app/.flutter-plugins
parent_app/.flutter-plugins-dependencies
parent_app/.idea/
parent_app/*.iml
parent_app/.packages
parent_app/pubspec.lock

# ─── Android ──────────────────────────────────────────────────────
parent_app/android/.gradle/
parent_app/android/local.properties
parent_app/android/key.properties
parent_app/android/app/debug.keystore
parent_app/android/app/release.keystore
parent_app/android/captures/

# ─── iOS ──────────────────────────────────────────────────────────
parent_app/ios/.symlinks/
parent_app/ios/Pods/
parent_app/ios/Flutter/Flutter.framework
parent_app/ios/Flutter/Flutter.podspec
parent_app/ios/Runner/GeneratedPluginRegistrant.m
parent_app/ios/Runner.xcworkspace/xcuserdata/

# ─── Prisma / Database ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── OS / Editor ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ─── Testing / Coverage ───────────────────────────────────────────
coverage/
.nyc_output/

# ─── Stitch exports / internal tooling ───────────────────────────
stitch_export/
convert_to_pdf.py

# ─── Docker ───────────────────────────────────────────────────────
*.pid

# ─── nginx: real certs / ACME challenge files never committed ──────
nginx/certs/*
!nginx/certs/README.md
nginx/certbot-www/*
!nginx/certbot-www/README.md

# ─── Deployment runtime state / local backups (never committed) ───
backups/
deploy/.last-deployed-commit

# ─── Real secret files (Firebase service account, etc.) ────────────
secrets/*
!secrets/README.md

# ─── Nested .git folders (treat subfolders as regular directories) ─
# Uncomment if you want to track dns-service and gateway-agent inline
# (they have their own .git repos currently)
